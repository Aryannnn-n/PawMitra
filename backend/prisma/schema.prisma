// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum PetStatus {
  LOST
  FOUND
  ADOPTABLE
  ADOPTED
  REUNITED
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PetGender {
  MALE
  FEMALE
  UNKNOWN
}

enum AdoptionStatus {
  PENDING
  APPROVED
  REJECTED
}


// USER
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  username  String   @unique @db.VarChar(255)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  age       Int?
  gender    Gender?
  phone     String?  @db.VarChar(20)
  location  String?  @db.VarChar(255)

  // Existing Relations
  pets        Pet[] @relation("OwnedPets")
  adoptedPets Pet[] @relation("AdoptedPets")

  // Adoption
  adoptionRequests AdoptionRequest[]

  // Notifications
  notifications Notification[]

  // Messaging
  sentMessages        Message[]        @relation("SentMessages")
  receivedMessages    Message[]        @relation("ReceivedMessages")
  roomParticipants    RoomParticipant[]
  roomMessages        RoomMessage[]
}


// PET
model Pet {
  id               Int              @id @default(autoincrement())
  name             String?          @db.VarChar(255)
  type             String           @db.VarChar(100)
  breed            String?          @db.VarChar(255)
  color            String?          @db.VarChar(100)
  gender           PetGender        @default(UNKNOWN)
  age              Int?
  wellness         String?          @db.VarChar(255)
  birthmark        String?          @db.Text

  // Cloudinary — client uploads directly, backend stores URL only
  imageUrl         String?          @db.VarChar(500)
  imagePublicId    String?          @db.VarChar(255)

  // Status
  status           PetStatus        @default(LOST)
  validationStatus ValidationStatus @default(PENDING)

  // Location
  state            String           @db.VarChar(255)
  city             String           @db.VarChar(255)
  village          String?          @db.VarChar(255)
  addressLine      String?          @db.VarChar(500)
  pincode          String?          @db.VarChar(20)
  googleMapsLink   String?          @db.VarChar(500)

  // Dates
  incidentDate     DateTime?
  dateReported     DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Owner (reporter)
  ownerId          Int
  owner            User             @relation("OwnedPets", fields: [ownerId], references: [id], onDelete: Cascade)

  // Adopter
  adoptedById      Int?
  adoptedBy        User?            @relation("AdoptedPets", fields: [adoptedById], references: [id], onDelete: SetNull)

  // Adoption Requests
  adoptionRequests AdoptionRequest[]

  // Chat Rooms
  chatRooms ChatRoom[]
}


// ADOPTION REQUEST
model AdoptionRequest {
  id          Int            @id @default(autoincrement())
  status      AdoptionStatus @default(PENDING)
  requestDate DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  petId       Int
  pet         Pet            @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@unique([userId, petId])
}


// NOTIFICATIONS
model Notification {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  isRead    Boolean  @default(false)
  timestamp DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// DIRECT MESSAGE (User → User)
model Message {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  isRead     Boolean  @default(false)
  timestamp  DateTime @default(now()) @db.Timestamptz

  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId Int
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}


// CHAT ROOM
model ChatRoom {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  isDisabled Boolean  @default(false)
  createdAt  DateTime @default(now())

  petId      Int?
  pet        Pet?     @relation(fields: [petId], references: [id], onDelete: SetNull)

  participants RoomParticipant[]
  messages     RoomMessage[]
}


// ROOM PARTICIPANTS
model RoomParticipant {
  id       Int      @id @default(autoincrement())
  joinedAt DateTime @default(now())

  roomId   Int
  room     ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userId   Int
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}


// ROOM MESSAGES
model RoomMessage {
  id        Int      @id @default(autoincrement())
  message   String   @db.Text
  timestamp DateTime @default(now()) @db.Timestamptz

  roomId    Int
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  senderId  Int
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
}